      "name": "pet",
      "item": [
        {
          "name": "Добавить нового питомца",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// сохранить ID питомца \r",
                  "let response=pm.response.json();\r",
                  "pm.environment.set(\"pet_ID\",response.id);\r",
                  "\r",
                  "//сохранить статус\r",
                  "let status=pm.response.json();\r",
                  "pm.environment.set(\"status\", status.status);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Генертруем случайное ID дляпитомца \r",
                  "let randomID = Math.floor(Math.random() * 1000) + 1;\r",
                  "pm.environment.set(\"randomID\",randomID)\r",
                  "\r",
                  "// Генерируем рандомную категорию из (dog, cat, hamster, fox, parrot)\r",
                  "let categories =[\"dog\", \"cat\", \"hamster\", \"fox\", \"parrot\"];\r",
                  "let randomCategory = categories[Math.floor(Math.random() * categories.length)];\r",
                  "pm.environment.set(\"randomCategory\",randomCategory)\r",
                  "\r",
                  "// Генерируем рандомное имя (Test, Barny, Ram, Button, Bella)\r",
                  "let names = [\"Test\", \"Barny\", \"Ram\", \"Button\", \"Bella\"];\r",
                  "let randomName = names[Math.floor(Math.random() * names.length)];\r",
                  "pm.environment.set(\"randomName\", randomName)\r",
                  "\r",
                  "// ID для категории\r",
                  "let categoryID = Math.floor(Math.random() * 100) + 1;\r",
                  "pm.environment.set(\"categoryID\",categoryID)\r",
                  "\r",
                  "// Случайный статус\r",
                  "let status = [\"available\", \"pending\", \"sold\"];\r",
                  "let randomStatus = status[Math.floor(Math.random() * status.length)];\r",
                  "pm.environment.set(\"randomStatus\", randomStatus)"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"id\": {{randomID}},\r\n  \"category\": {\r\n    \"id\": {{categoryID}},\r\n    \"name\": \"{{randomCategory}}\"\r\n  },\r\n  \"name\": \"{{randomName}}\",\r\n  \"photoUrls\": [\r\n    \"https://clck.ru/3QmVYJ\"\r\n  ],\r\n  \"tags\": [\r\n    {\r\n      \"id\": 2,\r\n      \"name\": \"breed\"\r\n    }\r\n  ],\r\n  \"status\": \"{{randomStatus}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}pet",
              "host": [
                "{{base_url}}pet"
              ]
            }
          },
          "response": []
        },
